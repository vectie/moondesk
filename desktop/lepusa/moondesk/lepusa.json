{
  "identifier": "app.vectie.moondesk.lepusa",
  "productName": "MoonDesk Lepusa",
  "version": "0.1.0",
  "runtime": {
    "backend": "system-webview",
    "assetProtocol": "lepusa",
    "devtools": false
  },
  "window": {
    "label": "main",
    "title": "MoonDesk",
    "width": 1280,
    "height": 820,
    "resizable": true,
    "source": { "packaged": "dist" }
  },
  "plugins": [
    { "name": "opener" },
    { "name": "browserHost" }
  ],
  "capabilities": [
    {
      "name": "main",
      "windows": ["main"],
      "permissions": [
        "opener",
        "custom:browserHost.execute",
        "custom:browserHost.complete",
        "custom:browserHost.captureScreenshot",
        "custom:browserHost.status"
      ]
    }
  ]
}
