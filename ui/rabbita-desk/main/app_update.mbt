///|
fn update(
  dispatch : Dispatch[Msg],
  msg : Msg,
  model : Model,
) -> (@rabbita.Cmd, Model) {
  match msg {
    Bootstrap => bootstrap_action(dispatch, model)
    LoadedWorkspaceMetadata(_) => update_app_results(dispatch, msg, model)
    LoadedWorkspaces(_) => update_app_results(dispatch, msg, model)
    LoadedEntries(_) => update_app_results(dispatch, msg, model)
    LoadedPreview(_) => update_app_results(dispatch, msg, model)
    LoadedRuns(_) => update_app_results(dispatch, msg, model)
    LoadedMoonFlowRuns(_) => update_app_results(dispatch, msg, model)
    ControlledMoonFlow(_) => update_app_results(dispatch, msg, model)
    LoadedTownMessages(_) => update_app_results(dispatch, msg, model)
    LoadedRequests(_) => update_app_results(dispatch, msg, model)
    LoadedStandingGoals(_) => update_app_results(dispatch, msg, model)
    LoadedAnalytics(_) => update_app_results(dispatch, msg, model)
    LoadedTownProgress(_) => update_app_results(dispatch, msg, model)
    LoadedMoonclawProgress(_) => update_app_results(dispatch, msg, model)
    LoadedEvents(_) => update_app_results(dispatch, msg, model)
    LoadedReviewItems(_) => update_app_results(dispatch, msg, model)
    LoadedSavedViews(_) => update_app_results(dispatch, msg, model)
    LoadedDaemonLifecycle(_) => update_app_results(dispatch, msg, model)
    LoadedSearch(_) => update_app_results(dispatch, msg, model)
    LoadedDeskTrash(_) => update_app_results(dispatch, msg, model)
    LoadedBookBaseTypes(_) => update_app_results(dispatch, msg, model)
    LoadedBookPatterns(_) => update_app_results(dispatch, msg, model)
    CreatedBlankMoonBook(_) => update_app_results(dispatch, msg, model)
    ImportedMoonBook(_) => update_app_results(dispatch, msg, model)
    LocalMoonBookFolderPicked(_) => update_app_results(dispatch, msg, model)
    LocalMoonBookArchivePicked(_) => update_app_results(dispatch, msg, model)
    CreatedDeskEntry(_) => update_app_results(dispatch, msg, model)
    RenamedDeskEntry(_) => update_app_results(dispatch, msg, model)
    MovedDeskEntry(_) => update_app_results(dispatch, msg, model)
    CopiedDeskEntry(_) => update_app_results(dispatch, msg, model)
    TrashedDeskEntry(_) => update_app_results(dispatch, msg, model)
    RestoredDeskEntry(_) => update_app_results(dispatch, msg, model)
    ImportedDeskFiles(_) => update_app_results(dispatch, msg, model)
    SavedInbox(_) => update_app_results(dispatch, msg, model)
    SavedMarkdownEdit(_) => update_app_results(dispatch, msg, model)
    ImportedInbox(_) => update_app_results(dispatch, msg, model)
    SavedView(_) => update_app_results(dispatch, msg, model)
    SubmittedRequest(_) => update_app_results(dispatch, msg, model)
    CreatedStandingGoal(_) => update_app_results(dispatch, msg, model)
    DecidedReviewItem(_) => update_app_results(dispatch, msg, model)
    CreatedBookFromPattern(_) => update_app_results(dispatch, msg, model)
    ExportedAppToolPortable(_) => update_app_results(dispatch, msg, model)
    ExportedAllAppToolPortable(_) => update_app_results(dispatch, msg, model)
    DispatchedDaemon(_) => update_app_results(dispatch, msg, model)
    ManagedDaemon(_) => update_app_results(dispatch, msg, model)
    LoadedLaunchAgent(_) => update_app_results(dispatch, msg, model)
    ManagedLaunchAgent(_) => update_app_results(dispatch, msg, model)
    RevealedSelection(_) => update_app_results(dispatch, msg, model)
    LocalFilesPicked(_) => update_app_results(dispatch, msg, model)
    LoadedMoonClawDaemon(_) => update_mooncode_results(dispatch, msg, model)
    LoadedMoonClawModels(_) => update_mooncode_results(dispatch, msg, model)
    LoadedMoonCodeSessions(_) => update_mooncode_results(dispatch, msg, model)
    LoadedMoonCodeSession(_, _) => update_mooncode_results(dispatch, msg, model)
    CreatedMoonCodeSession(_) => update_mooncode_results(dispatch, msg, model)
    CompletedMoonCodeCommand(_) => update_mooncode_results(dispatch, msg, model)
    SelectWorkspaceMode(_) => update_navigation_actions(dispatch, msg, model)
    ControlMoonFlow(_, _, _) =>
      update_workspace_surface_actions(dispatch, msg, model)
    SelectActivity(_) => update_navigation_actions(dispatch, msg, model)
    SelectWorkspace(_) => update_navigation_actions(dispatch, msg, model)
    SelectPath(_) => update_navigation_actions(dispatch, msg, model)
    OpenDirectory(_) => update_navigation_actions(dispatch, msg, model)
    NavigateDeskBack => update_navigation_actions(dispatch, msg, model)
    NavigateDeskForward => update_navigation_actions(dispatch, msg, model)
    SetDeskLocationInput(_) => update_navigation_actions(dispatch, msg, model)
    OpenDeskLocation => update_navigation_actions(dispatch, msg, model)
    OpenQuickPath(_) => update_navigation_actions(dispatch, msg, model)
    SelectSearchHit(_, _) => update_navigation_actions(dispatch, msg, model)
    ConfirmDiscardMarkdownNavigation =>
      update_navigation_actions(dispatch, msg, model)
    CancelDiscardMarkdownNavigation =>
      update_navigation_actions(dispatch, msg, model)
    SetNewBookName(_) => update_workspace_surface_actions(dispatch, msg, model)
    SetNewBookId(_) => update_workspace_surface_actions(dispatch, msg, model)
    CreateBlankMoonBook =>
      update_workspace_surface_actions(dispatch, msg, model)
    SetImportBookPath(_) =>
      update_workspace_surface_actions(dispatch, msg, model)
    ImportMoonBook => update_workspace_surface_actions(dispatch, msg, model)
    PickImportMoonBookFolder =>
      update_workspace_surface_actions(dispatch, msg, model)
    PickImportMoonBookArchive =>
      update_workspace_surface_actions(dispatch, msg, model)
    ToggleCommand => update_navigation_actions(dispatch, msg, model)
    SetCommandQuery(_) => update_navigation_actions(dispatch, msg, model)
    SetRequestPrompt(_) => update_town_actions(dispatch, msg, model)
    RemoveRequestMaterial(_) => update_town_actions(dispatch, msg, model)
    SubmitRequest => update_town_actions(dispatch, msg, model)
    SelectMoonCodeSession(_) => update_mooncode_actions(dispatch, msg, model)
    NewMoonCodeSession => update_mooncode_actions(dispatch, msg, model)
    SetMoonCodePrompt(_) => update_mooncode_actions(dispatch, msg, model)
    SendMoonCodeMessage => update_mooncode_actions(dispatch, msg, model)
    PollMoonCodeSessions(_) => update_mooncode_actions(dispatch, msg, model)
    SetGoalTitle(_) => update_book_builder_actions(dispatch, msg, model)
    SetGoalCadenceTicks(_) => update_book_builder_actions(dispatch, msg, model)
    SetGoalReviewPolicy(_) => update_book_builder_actions(dispatch, msg, model)
    SetGoalSourcePolicy(_) => update_book_builder_actions(dispatch, msg, model)
    SetBookPatternBookId(_) => update_book_builder_actions(dispatch, msg, model)
    SetBookPatternTopic(_) => update_book_builder_actions(dispatch, msg, model)
    SetBookPatternPurpose(_) =>
      update_book_builder_actions(dispatch, msg, model)
    SetBookPatternWebsites(_) =>
      update_book_builder_actions(dispatch, msg, model)
    SetBookPatternCadenceMinutes(_) =>
      update_book_builder_actions(dispatch, msg, model)
    SetBookPatternSourcePolicy(_) =>
      update_book_builder_actions(dispatch, msg, model)
    SetBookPatternNotifyRule(_) =>
      update_book_builder_actions(dispatch, msg, model)
    SetBookPatternSkillPack(_) =>
      update_book_builder_actions(dispatch, msg, model)
    SetBookPatternAnalysisMethod(_) =>
      update_book_builder_actions(dispatch, msg, model)
    SelectBookBaseType(_) => update_book_builder_actions(dispatch, msg, model)
    SelectBookPattern(_) => update_book_builder_actions(dispatch, msg, model)
    CreateStandingGoal => update_book_builder_actions(dispatch, msg, model)
    CreateBookFromPattern => update_book_builder_actions(dispatch, msg, model)
    ExportAppToolPortable => update_book_builder_actions(dispatch, msg, model)
    ExportAllAppToolPortable =>
      update_book_builder_actions(dispatch, msg, model)
    ControlDaemonTick => update_daemon_actions(dispatch, msg, model)
    FetchDaemonLifecycle => update_daemon_actions(dispatch, msg, model)
    StartDaemon => update_daemon_actions(dispatch, msg, model)
    StopDaemon => update_daemon_actions(dispatch, msg, model)
    RestartDaemon => update_daemon_actions(dispatch, msg, model)
    EnableDaemonSupervision => update_daemon_actions(dispatch, msg, model)
    DisableDaemonSupervision => update_daemon_actions(dispatch, msg, model)
    InstallLaunchAgent => update_daemon_actions(dispatch, msg, model)
    UninstallLaunchAgent => update_daemon_actions(dispatch, msg, model)
    RevealSelection => update_daemon_actions(dispatch, msg, model)
    SetInboxTitle(_) => update_inbox_actions(dispatch, msg, model)
    SetInboxContent(_) => update_inbox_actions(dispatch, msg, model)
    SetImportUrl(_) => update_inbox_actions(dispatch, msg, model)
    SetImportNote(_) => update_inbox_actions(dispatch, msg, model)
    ImportUrlToInbox => update_inbox_actions(dispatch, msg, model)
    ImportLocalFiles => update_inbox_actions(dispatch, msg, model)
    PollDroppedImports => update_inbox_actions(dispatch, msg, model)
    LoadSelectionIntoInbox => update_inbox_actions(dispatch, msg, model)
    SaveInboxNote => update_inbox_actions(dispatch, msg, model)
    StartMarkdownEdit => update_workspace_surface_actions(dispatch, msg, model)
    SetMarkdownEditorContent(_) =>
      update_workspace_surface_actions(dispatch, msg, model)
    CancelMarkdownEdit => update_workspace_surface_actions(dispatch, msg, model)
    SaveMarkdownEdit => update_workspace_surface_actions(dispatch, msg, model)
    StageSelectedLink => update_inbox_actions(dispatch, msg, model)
    SetSearchQuery(_) => update_workspace_surface_actions(dispatch, msg, model)
    SearchNow => update_workspace_surface_actions(dispatch, msg, model)
    SetDeskSort(_) => update_workspace_surface_actions(dispatch, msg, model)
    SetDeskFilterQuery(_) =>
      update_workspace_surface_actions(dispatch, msg, model)
    SetDeskDensity(_) => update_workspace_surface_actions(dispatch, msg, model)
    DeskKeyDown(_, _, _) =>
      update_workspace_surface_actions(dispatch, msg, model)
    DeskMouseDown(_, _, _) =>
      update_workspace_surface_actions(dispatch, msg, model)
    ClearDeskSelection => update_workspace_surface_actions(dispatch, msg, model)
    SetDeskNewItemName(_) =>
      update_workspace_surface_actions(dispatch, msg, model)
    CreateDeskFolder => update_workspace_surface_actions(dispatch, msg, model)
    CreateDeskMarkdown => update_workspace_surface_actions(dispatch, msg, model)
    ImportLocalFilesToDesk =>
      update_workspace_surface_actions(dispatch, msg, model)
    ImportLocalFolderToDesk =>
      update_workspace_surface_actions(dispatch, msg, model)
    StartDeskRename => update_workspace_surface_actions(dispatch, msg, model)
    CancelDeskRename => update_workspace_surface_actions(dispatch, msg, model)
    SetDeskRenameName(_) =>
      update_workspace_surface_actions(dispatch, msg, model)
    RenameDeskSelection =>
      update_workspace_surface_actions(dispatch, msg, model)
    SetDeskMoveTargetDirectory(_) =>
      update_workspace_surface_actions(dispatch, msg, model)
    MoveDeskSelection => update_workspace_surface_actions(dispatch, msg, model)
