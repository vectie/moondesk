    ExportAppToolPortable => update_book_builder_actions(dispatch, msg, model)
    ExportAllAppToolPortable => update_book_builder_actions(dispatch, msg, model)
    DispatchDaemonTick => update_daemon_actions(dispatch, msg, model)
    FetchDaemonLifecycle => update_daemon_actions(dispatch, msg, model)
    StartDaemon => update_daemon_actions(dispatch, msg, model)
    StopDaemon => update_daemon_actions(dispatch, msg, model)
    RestartDaemon => update_daemon_actions(dispatch, msg, model)
    EnableDaemonSupervision => update_daemon_actions(dispatch, msg, model)
    DisableDaemonSupervision => update_daemon_actions(dispatch, msg, model)
    InstallLaunchAgent => update_daemon_actions(dispatch, msg, model)
    UninstallLaunchAgent => update_daemon_actions(dispatch, msg, model)
    RevealSelection => update_daemon_actions(dispatch, msg, model)
    SetInboxTitle(_) => update_inbox_actions(dispatch, msg, model)
    SetInboxContent(_) => update_inbox_actions(dispatch, msg, model)
    SetImportUrl(_) => update_inbox_actions(dispatch, msg, model)
