///|
pub fn session_snapshot(
  session : Json,
  events : Array[Json],
  commands : Array[Json],
  runtime_commands : Array[Json],
  runtime_receipts : Array[Json],
  recorded_at~ : String,
  snapshot_path~ : String,
  command_log_path~ : String,
  runtime_command_log_path~ : String,
  runtime_receipt_log_path~ : String,
  event_log_path~ : String,
) -> Json {
  let normalized_runtime_receipts = runtime_receipts_for_response(
    runtime_receipts,
  )
  let session_id = json_string(session, "id", default="")
  {
    "kind": "mooncode-session-snapshot",
    "protocol": protocol_version(),
    "component": "mooncode",
    "session_id": session_id,
    "workspace_id": json_string(session, "workspace_id", default=""),
    "workspace_name": json_string(session, "workspace_name", default=""),
    "workspace_root": json_string(session, "workspace_root", default=""),
    "runtime_session_id": session_runtime_session_id(session),
    "title": json_string(session, "title", default=""),
    "model": json_string(session, "model", default=""),
    "status": json_string(session, "status", default=""),
    "created_at": json_string(session, "created_at", default=""),
    "updated_at": json_string(session, "updated_at", default=""),
    "recorded_at": recorded_at,
    "snapshot_path": snapshot_path,
    "command_log_path": command_log_path,
    "runtime_command_log_path": runtime_command_log_path,
    "runtime_receipt_log_path": runtime_receipt_log_path,
    "event_log_path": event_log_path,
    "commands": Json::array(commands),
    "command_count": commands.length(),
    "runtime_commands": Json::array(runtime_commands),
    "runtime_command_count": runtime_commands.length(),
    "runtime_receipts": Json::array(normalized_runtime_receipts),
    "runtime_receipt_count": normalized_runtime_receipts.length(),
    "runtime_receipt_pending_count": runtime_receipt_pending_count(
      runtime_commands,
      normalized_runtime_receipts,
      lease_now=recorded_at,
    ),
    "events": Json::array(events),
    "event_count": events.length(),
    "tool_call_contract": tool_call_contract_json(),
    "last_command_packet": summary_json_object_field_or_empty(
      session, "mooncode_last_command_packet",
    ),
    "last_runtime_handoff": summary_json_object_field_or_empty(
      session, "mooncode_last_runtime_handoff_manifest",
    ),
    "resume_endpoints": {
      "session_store": "/api/mooncode/sessions/\{session_id}/session-store",
      "runtime_handoff": "/api/mooncode/sessions/\{session_id}/runtime-handoff",
      "runtime_claim": "/api/mooncode/sessions/\{session_id}/runtime-claim",
      "runtime_replay": "/api/mooncode/sessions/\{session_id}/runtime-replay",
      "runtime_events": "/api/mooncode/sessions/\{session_id}/runtime-events",
      "runtime_commands": "/api/mooncode/sessions/\{session_id}/runtime-commands",
      "stream": "/api/mooncode/sessions/\{session_id}/stream?format=jsonl&since=<sequence>",
      "stream_state": "/api/mooncode/sessions/\{session_id}/stream-state?consumer=<consumer>&since=<sequence>",
      "action_plan": "/api/mooncode/sessions/\{session_id}/action-plan",
      "readiness": "/api/mooncode/sessions/\{session_id}/readiness",
    },
    "store_contract": {
      "shape": "typed session header plus commands.jsonl, runtime-commands.jsonl, runtime-receipts.jsonl, events.jsonl, and projected MoonCode events",
      "append_only_inputs": [
        "commands.jsonl", "runtime-commands.jsonl", "runtime-receipts.jsonl", "events.jsonl",
      ],
      "resume_modes": [
        "session_id", "session_snapshot", "command_log", "runtime_command_log", "runtime_receipt_log",
        "event_log", "runtime_handoff",
      ],
      "mooncode_reference": "mooncode/session + mooncode/session_store",
      "tool_call_contract": "tool-call and tool-result records in events.jsonl should satisfy the shared mooncode-tool-call-contract before runtime execution is trusted",
    },
    "event_normalization": {
      "owner": "mooncode",
      "function": "normalize_event_record",
      "id_policy": "preserve event.id when present; otherwise derive stable mooncode-event hash from lane, kind, title, created_at, and detail",
      "defaulted_fields": [
        "id", "lane", "kind", "title", "status", "created_at", "detail", "path",
        "diff", "command", "exit_code", "command_packet",
      ],
      "text_policy": "detail and diff are trimmed and capped before persistence or streaming",
      "consumer_note": "MoonClaw can resume this snapshot from the durable event log without depending on Moondesk HTTP projection logic for sparse runtime events.",
    },
    "owner": {
      "ui": "moondesk",
      "runtime": "moonclaw",
      "session_store": "mooncode",
      "standalone_component": "mooncode",
    },
  }
}
