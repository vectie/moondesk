///|
pub fn tool_contract_json() -> Json {
  {
    "kind": "mooncode-tool-contract",
    "protocol": protocol_version(),
    "version": 1,
    "owner": "moonclaw",
    "execution_owner": "moonclaw",
    "approval_owner": "moondesk",
    "artifact_owner": "moonbook",
    "supported_tools": string_array_json(runtime_tool_names()),
    "accepted_aliases": Json::array(runtime_tool_alias_rows()),
    "tools": Json::array([
      tool_contract_entry(
        id="read",
        lane="tool",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field(
            "path",
            "string",
            required=true,
            "Book-relative file path to read.",
          ),
          tool_field(
            "max_bytes",
            "integer",
            required=false,
            "Optional byte cap for bounded reads.",
          ),
        ],
        output_events=["tool_result"],
        safety_policy="Only read files inside the selected MoonBook workspace; never traverse outside the book root.",
      ),
      tool_contract_entry(
        id="edit",
        lane="diff",
        approval="review",
        mutates_files=true,
        requires_review=true,
        input_fields=[
          tool_field(
            "path",
            "string",
            required=true,
            "Book-relative file path to edit.",
          ),
          tool_field("old", "string", required=true, "Exact text to replace."),
          tool_field("new", "string", required=true, "Replacement text."),
        ],
        output_events=["file_change", "diff", "tool_result"],
        safety_policy="Emit a diff event for every edit and keep operator review state separate from execution.",
      ),
      tool_contract_entry(
        id="write",
        lane="diff",
        approval="review",
        mutates_files=true,
        requires_review=true,
        input_fields=[
          tool_field(
            "path",
            "string",
            required=true,
            "Book-relative file path to create or replace.",
          ),
          tool_field(
            "content",
            "string",
            required=true,
            "Complete UTF-8 file content.",
          ),
        ],
        output_events=["file_change", "diff", "tool_result"],
        safety_policy="Write only within allowed executable MoonBook roots such as tools, apps, portable/app-tool, site/generated, or reviewed wiki paths.",
      ),
      tool_contract_entry(
        id="apply_patch",
        lane="diff",
        approval="review",
        mutates_files=true,
        requires_review=true,
        input_fields=[
          tool_field(
            "patch",
            "string",
            required=true,
            "Unified patch text to apply inside the selected MoonBook.",
          ),
          tool_field(
            "paths",
            "array<string>",
            required=false,
            "Expected book-relative changed paths.",
          ),
        ],
        output_events=["file_change", "diff", "patch_applied", "tool_result"],
        safety_policy="Apply only reviewed patches under the selected MoonBook and emit patch_applied runtime proof.",
      ),
      tool_contract_entry(
        id="revert_patch",
        lane="diff",
        approval="review",
        mutates_files=true,
        requires_review=true,
        input_fields=[
          tool_field(
            "patch",
            "string",
            required=true,
            "Unified patch text to reverse inside the selected MoonBook.",
          ),
          tool_field(
            "paths",
            "array<string>",
            required=false,
            "Expected book-relative reverted paths.",
          ),
          tool_field(
            "receipt_id",
            "string",
            required=false,
            "Optional applied-patch receipt being reverted.",
          ),
        ],
        output_events=["file_change", "diff", "patch_reverted", "tool_result"],
        safety_policy="Revert only reviewed or previously applied patches under the selected MoonBook and emit patch_reverted runtime proof.",
      ),
      tool_contract_entry(
        id="shell",
        lane="tool",
        approval="policy",
        mutates_files=false,
        requires_review=true,
        input_fields=[
          tool_field(
            "cmd",
            "array<string>",
            required=true,
            "Argument-vector command, not a raw shell string.",
          ),
          tool_field(
            "cwd",
            "string",
            required=false,
            "Book-relative working directory.",
          ),
          tool_field(
            "timeout_ms",
            "integer",
            required=false,
            "Bounded execution timeout.",
          ),
        ],
        output_events=["tool_result", "runtime_update"],
        safety_policy="Run bounded commands under the selected book root; destructive or networked commands require explicit policy approval.",
      ),
      tool_contract_entry(
        id="moon_ide",
        lane="tool",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field(
            "action",
            "string",
            required=true,
            "Read-only MoonBit IDE action: doc, outline, peek_def, hover, or find_references.",
          ),
          tool_field(
            "query",
            "string",
            required=false,
            "Symbol or text query for doc, peek_def, hover, and find_references.",
          ),
          tool_field(
            "path",
            "string",
            required=false,
            "Book-relative package or file path for outline.",
          ),
          tool_field(
            "loc",
            "string",
            required=false,
            "Optional location as path:line:column for semantic navigation.",
          ),
          tool_field(
            "target",
            "string",
            required=false,
            "Optional MoonBit backend target.",
          ),
        ],
        output_events=["tool_result", "runtime_update"],
        safety_policy="Run read-only moon ide commands under the selected MoonBook root before broad file reads or edits.",
      ),
      tool_contract_entry(
        id="glob",
        lane="tool",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field(
            "pattern",
            "string",
            required=true,
            "Glob pattern to discover workspace files.",
          ),
          tool_field(
            "path",
            "string",
            required=false,
            "Optional book-relative directory to search.",
          ),
        ],
        output_events=["tool_result", "runtime_update"],
        safety_policy="Read-only file discovery inside the selected MoonBook workspace.",
      ),
      tool_contract_entry(
        id="grep",
        lane="tool",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field(
            "pattern",
            "string",
            required=true,
            "Regular expression pattern to search for.",
          ),
          tool_field(
            "path",
            "string",
            required=false,
            "Optional book-relative file or directory to search.",
          ),
          tool_field(
            "glob",
            "string",
            required=false,
            "Optional glob filter for matching files.",
          ),
        ],
        output_events=["tool_result", "runtime_update"],
        safety_policy="Read-only text search inside the selected MoonBook workspace.",
      ),
      tool_contract_entry(
        id="todo_write",
        lane="runtime",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field(
            "todos",
            "array<object>",
            required=true,
            "Current assistant plan items with content, status, and activeForm.",
          ),
        ],
        output_events=["runtime_update", "tool_result"],
        safety_policy="Planning-only progress signal; it must not modify workspace files.",
      ),
      tool_contract_entry(
        id="web_fetch",
        lane="tool",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field("url", "string", required=true, "URL to read."),
          tool_field(
            "prompt",
            "string",
            required=true,
            "Question or extraction prompt for the fetched page.",
          ),
        ],
        output_events=["tool_result", "runtime_update"],
        safety_policy="Only available when the command enables web_search; results are recorded as read-only context.",
      ),
      tool_contract_entry(
        id="web_search",
        lane="tool",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field("query", "string", required=true, "Search query."),
          tool_field(
            "allowed_domains",
            "array<string>",
            required=false,
            "Optional domain allow-list.",
          ),
          tool_field(
            "blocked_domains",
            "array<string>",
            required=false,
            "Optional domain block-list.",
          ),
        ],
        output_events=["tool_result", "runtime_update"],
        safety_policy="Only available when the command enables web_search; results are recorded as read-only context.",
      ),
      tool_contract_entry(
        id="moon_cmd",
        lane="test",
        approval="policy",
        mutates_files=true,
        requires_review=true,
        input_fields=[
          tool_field(
            "command",
            "string",
            required=true,
            "MoonBit command: check, test, run, info, fmt, or build.",
          ),
          tool_field(
            "cwd",
            "string",
            required=false,
            "Book-relative working directory.",
          ),
          tool_field(
            "target",
            "string",
            required=false,
            "Optional MoonBit backend target.",
          ),
          tool_field(
            "args",
            "array<string>",
            required=false,
            "Additional bounded MoonBit command arguments.",
          ),
          tool_field(
            "program_args",
            "array<string>",
            required=false,
            "Arguments after -- for moon run.",
          ),
          tool_field(
            "test_update_kind",
            "string",
            required=false,
            "Required when running snapshot-updating tests: stale_snapshot or intentional_output_change.",
          ),
        ],
        output_events=["tool_result", "test_result", "runtime_update", "diff"],
        safety_policy="Prefer structured MoonBit commands over raw shell; mutation-capable commands such as fmt or test --update require policy approval and diff/test proof.",
      ),
      tool_contract_entry(
        id="moon_check",
        lane="test",
        approval="auto",
        mutates_files=false,
        requires_review=false,
        input_fields=[
          tool_field(
            "target",
            "string",
            required=false,
            "Optional MoonBit package or file target.",
          ),
          tool_field(
            "command",
            "string",
            required=false,
            "check, test, build, fmt, or info.",
          ),
        ],
        output_events=["test_result", "tool_result"],
        safety_policy="Surface exit code, command, stdout/stderr summary, and failing target as test_result evidence.",
      ),
      tool_contract_entry(
        id="package_app_tool",
        lane="artifact",
        approval="operator",
        mutates_files=true,
        requires_review=true,
        input_fields=[
          tool_field(
            "source",
            "string",
            required=true,
            "Book-relative source path to package.",
          ),
          tool_field(
            "kind",
            "string",
            required=false,
            "tool, miniapp, generated-site, or app-tool.",
          ),
          tool_field(
            "output",
            "string",
            required=false,
            "Book-relative package output path.",
          ),
        ],
        output_events=[
          "diff", "artifact", "package.manifest", "package.index", "package_verified",
          "tool_result",
        ],
        safety_policy="Package accepted executable MoonBook output and emit source inventory plus package verification proof.",
      ),
      tool_contract_entry(
        id="finish",
        lane="review",
        approval="operator",
        mutates_files=false,
        requires_review=true,
        input_fields=[
          tool_field(
            "summary",
            "string",
            required=true,
            "Final implementation summary.",
          ),
          tool_field(
            "tests",
            "array<string>",
            required=false,
            "Validation commands and outcomes.",
          ),
          tool_field(
            "risks",
            "array<string>",
            required=false,
            "Residual risks or missing evidence.",
          ),
        ],
        output_events=["review", "runtime_finished"],
        safety_policy="Finish only after file changes, test evidence, and package readiness are available or explicitly called out as missing.",
      ),
    ]),
    "constraints": {
      "workspace_scope": "All paths are selected-MoonBook relative and must resolve inside the book root.",
      "path_rule": "MoonClaw validates paths before reading, writing, editing, packaging, or running tools.",
      "diff_rule": "Every mutating tool emits durable file_change and diff events before Moondesk can render accept/reject/package controls.",
      "test_rule": "run_tests and package actions are not complete until test_result or package artifact evidence is appended.",
      "approval_rule": "Moondesk records operator approval intent; MoonClaw enforces policy for shell, write/edit, and package execution.",
      "extraction_rule": "The schema is data-only and can move into a shared MoonCode protocol package without depending on Rabbita UI types.",
    },
  }
}

///|
pub fn tool_contract_tool_ids(contract : Json) -> Array[String] {
  let ids : Array[String] = []
  for tool in json_array_items(contract, "tools") {
    ids.push(json_string(tool, "id", default=""))
  }
  ids
}
